# Copy this file to `.env` and replace the placeholder values.
# The values here are examples for local development only — never reuse them in
# a shared or production environment. `.env` itself is git-ignored.

# Generate a strong key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-generated-secret-key

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection.
# Option A (recommended on Render/PaaS): a single connection URL. If set, it
# takes precedence over the DB_* variables below.
#   DATABASE_URL=postgres://user:password@host:5432/dbname
# Set DB_SSL_REQUIRE=True if your provider needs SSL (e.g. Render external host).
DATABASE_URL=
DB_SSL_REQUIRE=False

# Option B (local development): individual variables.
DB_NAME=trackora_db
DB_USER=postgres
DB_PASSWORD=replace-with-your-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS — origins of the frontend(s) allowed to call this API.
# In production set this to your Vercel URL, e.g. https://trackora.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# CSRF trusted origins — needed for the Django admin login over HTTPS.
# In production set this to your backend URL, e.g. https://trackora-api.onrender.com
CSRF_TRUSTED_ORIGINS=

# --- Production HTTPS (only applied when DEBUG=False) ---
# Set to False only if your host does not terminate TLS for you.
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=3600

# --- Media storage (product images) ---
# Local disk is fine for development. For production on an ephemeral host,
# set USE_S3=True and fill in S3-compatible credentials (AWS S3 / Cloudflare R2 / Supabase).
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
# Required for Cloudflare R2 / Supabase; leave blank for AWS S3:
AWS_S3_ENDPOINT_URL=
# Public URL/CDN domain for serving media (optional):
AWS_S3_CUSTOM_DOMAIN=
# Keep False for public images served via a public bucket/CDN:
AWS_QUERYSTRING_AUTH=False
