# Copy this file to `.env` and replace the placeholder values.
# The values here are examples for local development only — never reuse them in
# a shared or production environment. `.env` itself is git-ignored.

# Generate a strong key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-generated-secret-key

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection
DB_NAME=trackora_db
DB_USER=postgres
DB_PASSWORD=replace-with-your-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS — origins of the frontend(s) allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
